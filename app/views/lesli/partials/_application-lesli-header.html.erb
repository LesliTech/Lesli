<%
    engine_navigation_partial = navigation_partial
    dashboard_path = defined?(LesliDashboard) ? lesli_dashboard.root_path : "/"
    notifications_count = @lesli&.dig(:notifications).to_i

    header_action_class = "relative flex h-10 w-10 items-center justify-center rounded-xl text-slate-500 transition hover:bg-slate-100 hover:text-slate-950 focus:outline-none focus:ring-2 focus:ring-sky-500/30"
    logout_action_class = "relative flex h-10 w-10 items-center justify-center rounded-xl text-slate-500 transition hover:bg-red-50 hover:text-red-600 focus:outline-none focus:ring-2 focus:ring-red-500/20"
%>

<header class="border-b border-slate-200/80 bg-white">
    <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">

        <!-- Logo -->
        <%= link_to dashboard_path,
            class: "flex items-center",
            aria: { label: "Lesli Dashboard" },
            data: { turbo_frame: "_top" } do %>

            <div class="flex items-center [&_img]:h-12 [&_img]:w-auto">
                <%= customization_instance_logo_tag(
                    logo: "app-logo",
                    options: { alt: "Lesli app logo" }
                ) %>
            </div>
        <% end %>

        <%# Application actions %>
        <nav class="flex items-center gap-2" aria-label="Application actions">

            <% if defined?(LesliBell) %>
                <%= link_to lesli_bell.notifications_path,
                    class: header_action_class,
                    aria: { label: notifications_count.positive? ? "Notifications (#{notifications_count} unread)" : "Notifications" },
                    title: "Notifications",
                    data: { turbo_frame: "_top" } do %>

                    <i class="<%= notifications_count.positive? ? 'ri-notification-3-fill text-sky-600' : 'ri-notification-3-line' %> text-[24px] leading-none" aria-hidden="true"></i>

                    <% if notifications_count.positive? %>
                        <span class="absolute right-2.5 top-2.5 h-2 w-2 rounded-full bg-sky-500 ring-2 ring-white" aria-hidden="true"></span>
                    <% end %>
                <% end %>
            <% end %>

            <%= link_to lesli.apps_path,
                class: header_action_class,
                aria: { label: "Applications" },
                title: "Applications",
                data: { turbo_frame: "_top" } do %>
                <i class="ri-apps-2-line text-[24px] leading-none" aria-hidden="true"></i>
            <% end %>

            <% if defined?(LesliAdmin) %>
                <%= link_to lesli_admin.profile_path,
                    class: header_action_class,
                    aria: { label: "Profile" },
                    title: "Profile",
                    data: { turbo_frame: "_top" } do %>
                    <i class="ri-user-smile-line text-[24px] leading-none" aria-hidden="true"></i>
                <% end %>
            <% end %>

            <% if defined?(LesliShield) %>
                <%= link_to main_app.destroy_user_session_path,
                    class: logout_action_class,
                    aria: { label: "Logout" },
                    title: "Logout",
                    data: {
                        turbo_frame: "_top",
                        turbo_method: :delete
                    } do %>
                    <i class="ri-logout-circle-r-line text-[24px] leading-none" aria-hidden="true"></i>
                <% end %>
            <% end %>

        </nav>
    </div>
</header>

<%# Build the engine navigation %>
<% if engine_navigation_partial %>
    <nav class="border-b border-slate-200/80 bg-white" aria-label="Module navigation">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8" style="overflow-x: auto;">
            <ul class="flex h-14 items-center gap-1" style="width: max-content; margin-inline: auto;">
                <%= render(engine_navigation_partial) %>
            </ul>
        </div>
    </nav>
<% end %>
